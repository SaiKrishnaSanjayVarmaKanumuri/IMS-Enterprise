# Backend Configuration
PORT=3000
NODE_ENV=production
JWT_SECRET=your_jwt_secret_here
JWT_EXPIRES_IN=24h
BCRYPT_ROUNDS=12

# Database Configuration (Docker)
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=ims

# Database URL (Used by Prisma)
# For local dev with SQLite: file:./dev.db
# For Docker: postgresql://postgres:postgres@db:5432/ims?schema=public
DATABASE_URL=postgresql://postgres:postgres@db:5432/ims?schema=public

# Frontend Configuration
VITE_API_URL=http://localhost:3000/api
FRONTEND_URL=http://localhost:80
