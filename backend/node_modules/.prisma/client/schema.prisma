// Enterprise Inventory Management System — Prisma Schema
// PostgreSQL backend — Multi-site, RBAC, Vendor/PO/GRN, Analytics-ready

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================
// USER & AUTH MODELS
// ============================================

model User {
  id           String    @id @default(uuid())
  email        String    @unique
  passwordHash String
  firstName    String
  lastName     String
  role         String // ADMIN, SITE_ENGINEER, PROCUREMENT, FINANCE, FRONT_MAN
  isActive     Boolean   @default(true)
  phone        String?
  department   String?
  avatarUrl    String?
  lastLoginAt  DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  // Relations
  roleObj         Role?            @relation(fields: [role], references: [name])
  requests        Request[]
  assignedSites   Site[]
  approvalActions ApprovalAction[]
  auditLogs       AuditLog[]
  stockMovements  StockMovement[]
  purchaseOrders  PurchaseOrder[]
  notifications   Notification[]

  @@index([email])
  @@index([role])
}

model Role {
  id          String   @id @default(uuid())
  name        String   @unique
  description String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  permissions Permission[]
  users       User[]
}

model Permission {
  id          String   @id @default(uuid())
  name        String   @unique
  resource    String
  action      String
  description String
  createdAt   DateTime @default(now())

  roles Role[]

  @@index([resource, action])
}

// ============================================
// SITE / LOCATION MODELS
// ============================================

model Site {
  id             String   @id @default(uuid())
  name           String
  code           String   @unique
  address        String
  city           String?
  state          String?
  country        String?
  pincode        String?
  projectManager String?
  status         String   @default("active") // active, inactive, completed
  budgetLimit    Float?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  // Relations
  requests       Request[]
  assignedUsers  User[]
  targetRequests Request[]       @relation("TargetSite")
  inventoryItems InventoryItem[]
  stockMovements StockMovement[]
  purchaseOrders PurchaseOrder[]

  @@index([code])
  @@index([status])
}

// ============================================
// PRODUCT CATALOG MODELS
// ============================================

model Category {
  id          String     @id @default(uuid())
  name        String     @unique
  code        String     @unique
  description String?
  parentId    String?
  parent      Category?  @relation("CategoryHierarchy", fields: [parentId], references: [id])
  children    Category[] @relation("CategoryHierarchy")
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  products Product[]

  @@index([parentId])
}

model UnitOfMeasure {
  id           String   @id @default(uuid())
  name         String   @unique // "Kilogram", "Piece", "Meter"
  abbreviation String   @unique // "kg", "pcs", "m"
  type         String // "weight", "volume", "length", "count", "area"
  createdAt    DateTime @default(now())

  products     Product[]
  requestItems RequestItem[]
}

model Product {
  id             String        @id @default(uuid())
  name           String
  sku            String        @unique // Stock Keeping Unit
  description    String?
  specifications String?
  categoryId     String
  category       Category      @relation(fields: [categoryId], references: [id])
  unitId         String
  unit           UnitOfMeasure @relation(fields: [unitId], references: [id])

  // Pricing
  costPrice    Float  @default(0)
  sellingPrice Float?
  taxRate      Float  @default(0) // GST percentage

  // Physical
  weight       Float?
  dimensions   String? // JSON string: {l, w, h}
  hsnCode      String? // Harmonized System Nomenclature (tax code)
  barcodeValue String?

  isActive  Boolean @default(true)
  isTracked Boolean @default(true) // Whether to track inventory

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  inventoryItems     InventoryItem[]
  purchaseOrderItems PurchaseOrderItem[]

  @@index([sku])
  @@index([categoryId])
}

// ============================================
// VENDOR / SUPPLIER MODELS
// ============================================

model Vendor {
  id            String  @id @default(uuid())
  name          String
  code          String  @unique
  email         String?
  phone         String?
  contactPerson String?
  address       String?
  city          String?
  state         String?
  country       String?
  pincode       String?

  // Business details
  gstNumber    String?
  panNumber    String?
  paymentTerms Int     @default(30) // Days
  creditLimit  Float?
  rating       Float? // 1-5 star rating
  notes        String?

  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  purchaseOrders PurchaseOrder[]

  @@index([code])
  @@index([isActive])
}

// ============================================
// PURCHASE ORDER & GRN MODELS
// ============================================

model PurchaseOrder {
  id       String @id @default(uuid())
  poNumber String @unique
  status   String @default("DRAFT")
  // DRAFT → CONFIRMED → PARTIALLY_RECEIVED → RECEIVED → CLOSED → CANCELLED

  vendorId String
  vendor   Vendor @relation(fields: [vendorId], references: [id])

  siteId String
  site   Site   @relation(fields: [siteId], references: [id])

  createdById String
  createdBy   User   @relation(fields: [createdById], references: [id])

  // Dates
  orderDate    DateTime  @default(now())
  expectedDate DateTime?
  receivedDate DateTime?

  // Financials
  subtotal    Float  @default(0)
  taxAmount   Float  @default(0)
  totalAmount Float  @default(0)
  currency    String @default("INR")

  // Notes
  terms         String?
  notes         String?
  internalNotes String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  items    PurchaseOrderItem[]
  grnItems GRNItem[]

  @@index([poNumber])
  @@index([status])
  @@index([vendorId])
  @@index([siteId])
}

model PurchaseOrderItem {
  id              String        @id @default(uuid())
  purchaseOrderId String
  purchaseOrder   PurchaseOrder @relation(fields: [purchaseOrderId], references: [id], onDelete: Cascade)

  productId String
  product   Product @relation(fields: [productId], references: [id])

  description      String? // Override description
  quantity         Float
  receivedQuantity Float   @default(0)
  unitPrice        Float
  taxRate          Float   @default(0)
  totalPrice       Float

  notes     String?
  createdAt DateTime @default(now())

  grnItems GRNItem[]

  @@index([purchaseOrderId])
  @@index([productId])
}

model GRNItem {
  id              String        @id @default(uuid())
  purchaseOrderId String
  purchaseOrder   PurchaseOrder @relation(fields: [purchaseOrderId], references: [id])

  purchaseOrderItemId String
  purchaseOrderItem   PurchaseOrderItem @relation(fields: [purchaseOrderItemId], references: [id])

  // What was actually received
  receivedQuantity Float
  batchNumber      String?
  expiryDate       DateTime?
  notes            String?

  receivedAt DateTime @default(now())

  @@index([purchaseOrderId])
}

// ============================================
// REORDER RULES
// ============================================

model ReorderRule {
  id              String        @id @default(uuid())
  inventoryItemId String        @unique
  inventoryItem   InventoryItem @relation(fields: [inventoryItemId], references: [id])

  minQuantity     Float // Trigger reorder when stock falls below this
  maxQuantity     Float // Reorder target quantity
  reorderQuantity Float // How much to order

  preferredVendorId String? // Auto-populate in PO

  isActive        Boolean   @default(true)
  lastTriggeredAt DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
}

// ============================================
// NOTIFICATION MODEL
// ============================================

model Notification {
  id     String @id @default(uuid())
  userId String
  user   User   @relation(fields: [userId], references: [id])

  type    String // "LOW_STOCK", "PO_CONFIRMED", "REQUEST_APPROVED", "GRN_RECEIVED", etc.
  title   String
  message String
  link    String? // Deep link to the resource

  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([userId, isRead])
  @@index([createdAt])
}

// ============================================
// REQUEST MODELS
// ============================================

model Request {
  id            String @id @default(uuid())
  requestNumber String @unique
  type          String // MATERIAL, SHIFTING
  status        String @default("PENDING")
  priority      String @default("normal")

  requesterId String
  requester   User   @relation(fields: [requesterId], references: [id])

  siteId String
  site   Site   @relation(fields: [siteId], references: [id])

  targetSiteId String?
  targetSite   Site?   @relation("TargetSite", fields: [targetSiteId], references: [id])

  description   String
  justification String?
  expectedDate  DateTime?

  estimatedCost Float?
  actualCost    Float?
  budgetCode    String?

  vendorId         String?
  vendorName       String?
  poNumber         String?
  procurementNotes String?
  financeNotes     String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  items           RequestItem[]
  approvalActions ApprovalAction[]
  auditLogs       AuditLog[]

  @@index([requestNumber])
  @@index([status])
  @@index([requesterId])
  @@index([siteId])
}

model RequestItem {
  id        String  @id @default(uuid())
  requestId String
  request   Request @relation(fields: [requestId], references: [id], onDelete: Cascade)

  itemName       String
  quantity       Float
  unitId         String?
  unit           UnitOfMeasure? @relation(fields: [unitId], references: [id])
  unitLabel      String // Legacy/fallback text unit
  specifications String?
  notes          String?
  estimatedPrice Float?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([requestId])
}

model ApprovalAction {
  id        String  @id @default(uuid())
  requestId String
  request   Request @relation(fields: [requestId], references: [id])

  approverId String
  approver   User   @relation(fields: [approverId], references: [id])

  action     String
  fromStatus String
  toStatus   String
  remarks    String?

  createdAt DateTime @default(now())

  @@index([requestId])
  @@index([approverId])
}

// ============================================
// INVENTORY MODELS
// ============================================

model InventoryItem {
  id       String @id @default(uuid())
  name     String
  code     String
  category String
  unit     String // Legacy text unit

  // Link to global catalog (optional — can exist without product)
  productId String?
  product   Product? @relation(fields: [productId], references: [id])

  currentStock Float  @default(0)
  minimumStock Float  @default(0)
  maximumStock Float?
  costPrice    Float  @default(0) // Current unit cost

  siteId String
  site   Site   @relation(fields: [siteId], references: [id])

  description    String?
  specifications String?
  location       String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  movements   StockMovement[]
  alerts      Alert[]
  reorderRule ReorderRule?

  @@unique([siteId, code])
  @@index([siteId])
  @@index([category])
  @@index([productId])
}

model StockMovement {
  id String @id @default(uuid())

  type          String // "ADD", "CONSUME", "TRANSFER_IN", "TRANSFER_OUT", "ADJUSTMENT"
  quantity      Float
  previousStock Float
  newStock      Float
  unitCost      Float  @default(0)

  inventoryItemId String
  inventoryItem   InventoryItem @relation(fields: [inventoryItemId], references: [id])

  performedById String
  performedBy   User   @relation(fields: [performedById], references: [id])
  siteId        String
  site          Site   @relation(fields: [siteId], references: [id])

  // References
  reason      String?
  reference   String? // PO number, request ID, etc.
  batchNumber String?
  notes       String?

  createdAt DateTime @default(now())

  @@index([inventoryItemId])
  @@index([performedById])
  @@index([siteId])
  @@index([type])
  @@index([createdAt])
}

model Alert {
  id String @id @default(uuid())

  type     String @default("low_stock")
  severity String @default("warning")
  message  String

  inventoryItemId String
  inventoryItem   InventoryItem @relation(fields: [inventoryItemId], references: [id])

  isRead   Boolean @default(false)
  isActive Boolean @default(true)

  createdAt  DateTime  @default(now())
  resolvedAt DateTime?

  @@index([inventoryItemId])
  @@index([type])
  @@index([isActive])
  @@index([createdAt])
}

// ============================================
// AUDIT LOG
// ============================================

model AuditLog {
  id     String  @id @default(uuid())
  userId String?
  user   User?   @relation(fields: [userId], references: [id])

  requestId String?
  request   Request? @relation(fields: [requestId], references: [id])

  action     String
  resource   String
  resourceId String?
  siteId     String?

  details   String? // JSON string
  ipAddress String?
  userAgent String?

  status       String  @default("success")
  errorMessage String?

  createdAt DateTime @default(now())

  @@index([userId])
  @@index([action])
  @@index([resource])
  @@index([siteId])
  @@index([createdAt])
}
