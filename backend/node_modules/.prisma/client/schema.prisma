// Prisma Schema for Construction Inventory Management System
// Strict RBAC with Admin-controlled roles
// Using SQLite-compatible types (no enums)

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// ============================================
// MODELS - Using String for role/status fields for SQLite compatibility
// ============================================

// User model - role assigned by Admin only
model User {
  id           String   @id @default(uuid())
  email        String   @unique
  passwordHash String
  firstName    String
  lastName     String
  role         String // ADMIN, SITE_ENGINEER, PROCUREMENT, FINANCE, FRONT_MAN
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  // Relations
  roleObj         Role?            @relation(fields: [role], references: [name])
  requests        Request[] // Requests raised by this user (FM)
  assignedSites   Site[] // Sites assigned to this user (FM/Engineer)
  approvalActions ApprovalAction[]
  auditLogs       AuditLog[]
  stockMovements  StockMovement[]

  @@index([email])
  @@index([role])
}

// Role model - Admin-defined only, users cannot modify
model Role {
  id          String   @id @default(uuid())
  name        String   @unique // ADMIN, SITE_ENGINEER, etc.
  description String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relations
  permissions Permission[]
  users       User[]
}

// Permission model - Granular permissions assigned to roles
model Permission {
  id          String   @id @default(uuid())
  name        String   @unique // e.g., "requests.create", "requests.approve.engineer"
  resource    String // e.g., "requests", "sites", "users"
  action      String // e.g., "create", "read", "update", "delete", "approve"
  description String
  createdAt   DateTime @default(now())

  // Relations
  roles Role[]

  @@index([resource, action])
}

// Site model - Construction sites/projects
model Site {
  id             String   @id @default(uuid())
  name           String
  code           String   @unique
  address        String
  projectManager String?
  status         String   @default("active") // active, inactive, completed
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  // Relations
  requests       Request[]
  assignedUsers  User[]
  targetRequests Request[]       @relation("TargetSite")
  inventoryItems InventoryItem[]
  stockMovements StockMovement[]

  @@index([code])
  @@index([status])
}

// Request model - Material/shifting requests
model Request {
  id            String @id @default(uuid())
  requestNumber String @unique
  type          String // MATERIAL, SHIFTING
  status        String @default("PENDING")
  priority      String @default("normal") // low, normal, high, urgent

  // Requester info
  requesterId String
  requester   User   @relation(fields: [requesterId], references: [id])

  // Site info
  siteId String
  site   Site   @relation(fields: [siteId], references: [id])

  // Target site (for shifting requests)
  targetSiteId String?
  targetSite   Site?   @relation("TargetSite", fields: [targetSiteId], references: [id])

  // Details
  description   String
  justification String?
  expectedDate  DateTime?

  // Financial info
  estimatedCost Float?
  actualCost    Float?
  budgetCode    String?

  // Vendor info (Procurement)
  vendorId   String?
  vendorName String?
  poNumber   String?

  // Procurement notes
  procurementNotes String?

  // Finance notes
  financeNotes String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  items           RequestItem[]
  approvalActions ApprovalAction[]
  auditLogs       AuditLog[]

  @@index([requestNumber])
  @@index([status])
  @@index([requesterId])
  @@index([siteId])
}

// Request items - Line items in a request
model RequestItem {
  id        String  @id @default(uuid())
  requestId String
  request   Request @relation(fields: [requestId], references: [id], onDelete: Cascade)

  itemName       String
  quantity       Float
  unit           String
  specifications String?
  notes          String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([requestId])
}

// Approval actions - Tracks each approval/rejection step
model ApprovalAction {
  id        String  @id @default(uuid())
  requestId String
  request   Request @relation(fields: [requestId], references: [id])

  approverId String
  approver   User   @relation(fields: [approverId], references: [id])

  action     String // "approve" or "reject"
  fromStatus String
  toStatus   String

  remarks String?

  createdAt DateTime @default(now())

  @@index([requestId])
  @@index([approverId])
}

// Audit log - All actions logged for security
model AuditLog {
  id     String  @id @default(uuid())
  userId String?
  user   User?   @relation(fields: [userId], references: [id])

  requestId String?
  request   Request? @relation(fields: [requestId], references: [id])

  action     String // e.g., "login", "request.create", "request.approve"
  resource   String // e.g., "auth", "requests", "users", "inventory"
  resourceId String? // ID of the affected resource
  siteId     String? // Site from which the action was performed

  details   String? // JSON string with additional details
  ipAddress String?
  userAgent String?

  status       String  @default("success") // "success" or "failed"
  errorMessage String?

  createdAt DateTime @default(now())

  @@index([userId])
  @@index([action])
  @@index([resource])
  @@index([siteId])
  @@index([createdAt])
}

// ============================================
// INVENTORY MODELS
// ============================================

// Inventory items stored at sites
model InventoryItem {
  id       String @id @default(uuid())
  name     String // e.g., "Cement", "Steel Rods", "Bricks"
  code     String // Unique code for the item
  category String // e.g., "raw_materials", "tools", "equipment"
  unit     String // e.g., "kg", "pieces", "tons", "liters"

  // Current stock levels
  currentStock Float  @default(0)
  minimumStock Float  @default(0) // Low stock threshold
  maximumStock Float? // Optional maximum capacity

  // Location
  siteId String
  site   Site   @relation(fields: [siteId], references: [id])

  // Metadata
  description    String?
  specifications String?
  location       String? // Specific location within site

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  movements StockMovement[]
  alerts    Alert[]

  @@unique([siteId, code]) // Item code unique per site
  @@index([siteId])
  @@index([category])
}

// Stock movements - tracks all add/consume operations
model StockMovement {
  id String @id @default(uuid())

  // Movement details
  type          String // "ADD" or "CONSUME"
  quantity      Float // Amount added or consumed
  previousStock Float // Stock before this movement
  newStock      Float // Stock after this movement

  // Reference
  inventoryItemId String
  inventoryItem   InventoryItem @relation(fields: [inventoryItemId], references: [id])

  // Who made the change
  performedById String
  performedBy   User   @relation(fields: [performedById], references: [id])
  siteId        String // Site from which the action was performed
  site          Site   @relation(fields: [siteId], references: [id])

  // Additional details
  reason    String? // e.g., "Delivery", "Construction use", "Damaged"
  reference String? // e.g., PO number, request ID
  notes     String?

  createdAt DateTime @default(now())

  @@index([inventoryItemId])
  @@index([performedById])
  @@index([siteId])
  @@index([type])
  @@index([createdAt])
}

// Low stock alerts
model Alert {
  id String @id @default(uuid())

  // Alert details
  type     String @default("low_stock")
  severity String @default("warning") // "info", "warning", "critical"
  message  String

  // Related item
  inventoryItemId String
  inventoryItem   InventoryItem @relation(fields: [inventoryItemId], references: [id])

  // Status
  isRead   Boolean @default(false)
  isActive Boolean @default(true)

  createdAt  DateTime  @default(now())
  resolvedAt DateTime?

  @@index([inventoryItemId])
  @@index([type])
  @@index([isActive])
  @@index([createdAt])
}
